# Environment variables example for sim-logistics-frontend

# Mock mode - set to 'true' to use mock data instead of real backend
VITE_USE_MOCK=false

# API base URL (relative path for Vite proxy)
VITE_API_BASE_URL=/api/v1

# WebSocket base URL (relative path for Vite proxy)
VITE_WS_BASE_URL=/ws

# Backend proxy target for development
VITE_DEV_PROXY_TARGET=http://localhost:34512
