{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/stocker.json",
  "title": "Stocker Entity (ASRS)",
  "description": "Automated Storage and Retrieval System",
  "allOf": [
    {
      "$ref": "entity-base.json#/definitions/entity"
    },
    {
      "$ref": "entity-base.json#/definitions/transport-capable"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "STOCKER"
        },
        "properties": {
          "type": "object",
          "properties": {
            "capacity": {
              "type": "integer",
              "minimum": 1,
              "description": "Total storage capacity"
            },
            "usedCapacity": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Currently used storage slots"
            },
            "craneCount": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Number of stacker cranes"
            },
            "throughput": {
              "type": "number",
              "minimum": 0,
              "description": "Target throughput (operations/hour)"
            },
            "loadTime": {
              "type": "number",
              "minimum": 0,
              "default": 30,
              "description": "Load time in seconds"
            },
            "unloadTime": {
              "type": "number",
              "minimum": 0,
              "default": 30,
              "description": "Unload time in seconds"
            }
          },
          "required": ["capacity", "craneCount"]
        }
      }
    }
  ]
}
