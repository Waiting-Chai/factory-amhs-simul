{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/operator.json",
  "title": "Operator Entity",
  "description": "Human operator for manual operations",
  "allOf": [
    {
      "$ref": "entity-base.json#/definitions/entity"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "OPERATOR"
        },
        "properties": {
          "type": "object",
          "properties": {
            "skills": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "List of operator skills"
            },
            "efficiency": {
              "type": "number",
              "minimum": 0,
              "maximum": 2,
              "default": 1,
              "description": "Operator efficiency multiplier (1.0 = standard)"
            },
            "shiftStart": {
              "type": "string",
              "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$",
              "description": "Shift start time (HH:MM)"
            },
            "shiftEnd": {
              "type": "string",
              "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$",
              "description": "Shift end time (HH:MM)"
            },
            "state": {
              "type": "string",
              "enum": ["IDLE", "WORKING", "BREAK", "OFF_DUTY"],
              "default": "IDLE"
            }
          },
          "required": ["skills"]
        }
      }
    }
  ]
}
