{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/oht-vehicle.json",
  "title": "OHT Vehicle Entity",
  "description": "Overhead Hoist Transport vehicle for rail-based transport",
  "allOf": [
    {
      "$ref": "entity-base.json#/definitions/entity"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "OHT_VEHICLE"
        },
        "properties": {
          "type": "object",
          "properties": {
            "trackId": {
              "type": "string",
              "description": "Associated track ID"
            },
            "maxLoad": {
              "type": "number",
              "minimum": 0,
              "description": "Maximum load capacity in kg"
            },
            "currentLoad": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "Current load in kg"
            },
            "speed": {
              "type": "number",
              "minimum": 0,
              "description": "Travel speed in m/s"
            },
            "liftSpeed": {
              "type": "number",
              "minimum": 0,
              "default": 0.5,
              "description": "Lift speed in m/s"
            },
            "state": {
              "type": "string",
              "enum": ["IDLE", "MOVING", "LOADING", "UNLOADING", "CHARGING", "BLOCKED", "ERROR"],
              "default": "IDLE"
            },
            "batteryLevel": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 1,
              "description": "Battery level (0-1)"
            },
            "path": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Current path (list of point IDs)"
            }
          },
          "required": ["trackId", "maxLoad", "speed"]
        }
      }
    }
  ]
}
