{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/manual-station.json",
  "title": "Manual Station Entity",
  "description": "Manual workstation operated by human operators",
  "allOf": [
    {
      "$ref": "entity-base.json#/definitions/entity"
    },
    {
      "$ref": "entity-base.json#/definitions/transport-capable"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "MANUAL_STATION"
        },
        "properties": {
          "type": "object",
          "properties": {
            "capacity": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Number of operators that can work simultaneously"
            },
            "assignedOperators": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Assigned operator IDs"
            },
            "defaultOperationTime": {
              "type": "number",
              "minimum": 0,
              "default": 60,
              "description": "Default operation time in seconds"
            }
          }
        }
      }
    }
  ]
}
