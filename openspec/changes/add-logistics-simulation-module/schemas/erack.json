{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/erack.json",
  "title": "E-Rack Entity",
  "description": "Equipment Rack / Buffer storage for temporary material placement",
  "allOf": [
    {
      "$ref": "entity-base.json#/definitions/entity"
    },
    {
      "$ref": "entity-base.json#/definitions/transport-capable"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "ERACK"
        },
        "properties": {
          "type": "object",
          "properties": {
            "capacity": {
              "type": "integer",
              "minimum": 1,
              "description": "Total storage capacity"
            },
            "usedCapacity": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Currently used slots"
            }
          },
          "required": ["capacity"]
        }
      }
    }
  ]
}
